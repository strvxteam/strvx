# Supabase — required
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Calendly webhook — required for production (fail-closed without it)
CALENDLY_WEBHOOK_SECRET="whsec_..."

# Dev only — never set in production
# BYPASS_AUTH="true"

# Stripe — required for invoicing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google OAuth — required for Calendar/Drive
GOOGLE_CLIENT_ID="...apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."
# Local: http://localhost:3000/api/auth/google/callback
# Production: https://app.strvx.com/api/auth/google/callback
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Encryption — required for Google token encryption (64 hex chars / 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="..."

# Apollo — optional (prospect search)
APOLLO_API_KEY="..."

# GitHub — optional (repo listing)
GITHUB_TOKEN="ghp_..."

# Booking webhook — required for production
BOOKING_WEBHOOK_SECRET="..."

# Sentry — error monitoring (optional, only needed in production)
NEXT_PUBLIC_SENTRY_DSN="https://...@....ingest.sentry.io/..."
SENTRY_AUTH_TOKEN="sntrys_..."
