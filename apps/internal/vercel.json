{
  "crons": [
    {
      "path": "/api/monitor/check?secret=${MONITOR_SECRET}",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/dev/refresh?secret=${DEV_OPS_REFRESH_SECRET}",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/reports/weekly?secret=${WEEKLY_REPORT_SECRET}",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/generate-invoices",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cleanup/ui-state?secret=${UI_STATE_CLEANUP_SECRET}",
      "schedule": "0 5 * * *"
    }
  ]
}
