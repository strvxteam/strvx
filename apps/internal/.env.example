# Development (DevOps) — added 2026-04-17
# GitHub fine-grained PAT with read access to Actions, PRs, Dependabot alerts, metadata
GITHUB_TOKEN=

# Vercel access token (Account Settings → Tokens)
VERCEL_TOKEN=
# Optional — Vercel team ID. Personal account = leave blank.
VERCEL_TEAM_ID=

# Shared secret for /api/dev/refresh cron
DEV_OPS_REFRESH_SECRET=

# Base URL used by server actions to call /api/dev/refresh
# Local: http://localhost:3100
# Prod: https://sit.strvx.com (or your deployed URL)
NEXT_PUBLIC_APP_URL=
